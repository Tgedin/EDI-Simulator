{
  "uid": "edi-simulator-main",
  "title": "EDI Simulator",
  "tags": ["edi"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Messages / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(rate(edi_messages_processed_total[1m])) * 60", "legendFormat": "msg/min", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Queue Depth",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } },
      "targets": [{ "expr": "sum(edi_queue_depth)", "legendFormat": "depth", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Transform Success %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 80 }, { "color": "green", "value": 95 }] } } },
      "targets": [{ "expr": "100 * sum(rate(edi_transformations_total{status=\"success\"}[5m])) / (sum(rate(edi_transformations_total[5m])) > 0)", "legendFormat": "success %", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DLQ Messages (1h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } },
      "targets": [{ "expr": "sum(increase(edi_dlq_messages_total[1h]))", "legendFormat": "DLQ", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Message Flow by Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by(status) (rate(edi_messages_processed_total[1m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Requests / sec",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by(path, status_code) (rate(edi_http_requests_total[1m]))", "legendFormat": "{{path}} {{status_code}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "P95 Processing Latency",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, service) (rate(edi_message_processing_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{service}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Simulator Throughput",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum by(format, malformed) (rate(edi_simulator_messages_total[1m]))", "legendFormat": "{{format}} malformed={{malformed}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent Error Logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "uid": "loki" },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "wrapLogMessage": true },
      "targets": [
        { "expr": "{job=\"edi-simulator\"} |= \"error\" | json | level =~ \"ERROR|WARN\"", "legendFormat": "", "refId": "A" }
      ]
    }
  ]
}
